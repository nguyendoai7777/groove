{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "groovex",
	"version": "0.1.0",
	"identifier": "com.mrdxd.groovex",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "groovex",
				"width": 800,
				"height": 600,
				"decorations": false,
				"transparent": true,
				"shadow": false
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"resources": [
			"icons/taskbar/*"
		]
	},
	"plugins": {
		"taskbar": {
			"autoAttach": true,
			"windowLabel": "main",
			"events": {
				"previous": "media-prev",
				"toggle": "media-toggle",
				"next": "media-next"
			},
			"tooltips": {
				"previous": "Previous",
				"play": "Play",
				"pause": "Pause",
				"next": "Next"
			},
			"icons": {
				"previous": "icons/taskbar/prev.ico",
				"previousDisabled": "icons/taskbar/prev.ico",
				"play": "icons/taskbar/play.ico",
				"pause": "icons/taskbar/pause.ico",
				"next": "icons/taskbar/next.ico",
				"nextDisabled": "icons/taskbar/next.ico"
			}
		}
	}
}
